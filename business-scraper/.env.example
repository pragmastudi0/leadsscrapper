# Configuración de búsqueda
SEARCH_KEYWORDS=restaurante,cafetería,peluquería
SEARCH_CITIES=Córdoba,Buenos Aires,Rosario
SEARCH_LIMIT=100

# Google Maps
GOOGLE_MAPS_HEADLESS=true
GOOGLE_MAPS_TIMEOUT=30000

# Instagram
INSTAGRAM_HEADLESS=true
INSTAGRAM_TIMEOUT=20000

# Google Sheets (opcional)
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials.json

# Configuración general
LOG_LEVEL=info
DELAY_MIN=1000
DELAY_MAX=3000
EXCLUDE_CHAINS=true
